# Required: Slack credentials (from https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# RAG pipeline: Slack user token for fetching channel history (xoxe.xoxp-...)
SLACK_USER_TOKEN=xoxe.xoxp-your-user-token-here

# Required: Google Cloud / Vertex AI
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json
GOOGLE_CLOUD_PROJECT=logistics-customer-staging
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-2.5-flash

# Optional: Jira Cloud (for ticket lookups)
JIRA_URL=https://deliveryhero.atlassian.net
# Confluence URL — only needed if different from JIRA_URL
CONFLUENCE_URL=https://deliveryhero.atlassian.net
JIRA_EMAIL=your-email@deliveryhero.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_DEFAULT_PROJECT=CLOGBI

# Optional: Slack channel ID to auto-reply in (leave blank to disable auto-reply)
PRICING_CHANNEL_ID=

# Optional: Slack user IDs allowed to submit doc corrections (comma-separated)
FEEDBACK_USERS=

# Optional: Slack user group to tag when bot is uncertain (handle or subteam ID starting with S)
ESCALATION_GROUP=cpl-pricing-analytics

# Optional: GCS bucket for RAG index (leave blank to use bundled index)
GCS_RAG_BUCKET=
